#version 430

layout(local_size_x = 1, local_size_y = 1) in;

layout(std430, binding = 0) readonly buffer TileCounter {
    uint tileCount;
};

layout(std430, binding = 1) buffer DispatchCommand {
    uint groupsX;
    uint groupsY;
    uint groupsZ;
};

void main() {
    groupsX = max(tileCount, 1u);
    groupsY = 1u;
    groupsZ = 1u;
}
